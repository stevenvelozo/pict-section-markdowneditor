{
	"Kind":              "section",
	"WrapperKind":       "view",
	"SectionType":       "pict-section-markdowneditor",
	"ApplicationModule": "PictSectionMarkdowneditor",
	"ApplicationGlobal": "PictSectionMarkdowneditor",
	"ViewName":          "MarkdownEditor",
	"ViewConfigKey":     "MarkdownEditorViewConfig",
	"ManifestKey":       "DefaultMarkdownEditorManifest",
	"MountID":           "MarkdownEditor-Container-Div",
	"Editors":
	[
		{ "Hash": "pictConfig",  "Label": "Pict Config",       "Language": "json",       "DefaultPath": "playground/pict.json" },
		{ "Hash": "appConfig",   "Label": "App Config",        "Language": "json",       "DefaultPath": "playground/app.json" },
		{ "Hash": "appData",     "Label": "Initial AppData",   "Language": "json",       "DefaultPath": "playground/appdata.json" },
		{ "Hash": "application", "Label": "Application Code",  "Language": "javascript", "DefaultPath": "playground/application.js" }
	],
	"Imports":
	[
		{ "Name": "pict",                        "Source": "local", "Path": "playground/runtime/pict.min.js" },
		{ "Name": "pict-application",            "Source": "local", "Path": "playground/runtime/pict-application.min.js" },
		{ "Name": "pict-section-modal",          "Source": "local", "Path": "playground/runtime/pict-section-modal.min.js" },
		{ "Name": "pict-section-markdowneditor", "Source": "local", "Path": "playground/runtime/pict-section-markdowneditor.min.js" },
		{ "Name": "codemirror-view",     "Source": "esm", "URL": "https://esm.run/@codemirror/view@6",          "GlobalName": "CodeMirrorView",     "ExportName": "*" },
		{ "Name": "codemirror-state",    "Source": "esm", "URL": "https://esm.run/@codemirror/state@6",         "GlobalName": "CodeMirrorState",    "ExportName": "*" },
		{ "Name": "codemirror-basic",    "Source": "esm", "URL": "https://esm.run/codemirror@6",                "GlobalName": "CodeMirrorBasic",    "ExportName": "*" },
		{ "Name": "codemirror-markdown", "Source": "esm", "URL": "https://esm.run/@codemirror/lang-markdown@6", "GlobalName": "CodeMirrorMarkdown", "ExportName": "*" }
	]
}
